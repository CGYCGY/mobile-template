# Convex
# Run `bunx convex dev` to get your deployment URL
EXPO_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# WorkOS — https://dashboard.workos.com
EXPO_PUBLIC_WORKOS_CLIENT_ID=client_01XXXXXXXXXXXXXXXXXX
# Must match the Redirect URI set in WorkOS dashboard → Authentication.
# The scheme must also match `expo.scheme` in app.json.
EXPO_PUBLIC_WORKOS_REDIRECT_URI=mobiletemplate://auth/callback

# PostHog product analytics — https://posthog.com
EXPO_PUBLIC_POSTHOG_KEY=phc_XXXXXXXXXXXXXXXXXX
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sentry — https://sentry.io
# DSN must be EXPO_PUBLIC_ so babel-preset-expo inlines it into the device bundle.
# Auth token is build-time only (Sentry CLI sourcemap upload); never bundled.
EXPO_PUBLIC_SENTRY_DSN=https://XXXXXXXXXXXXXXXX@oXXXXXX.ingest.sentry.io/XXXXXXX
SENTRY_AUTH_TOKEN=sntrys_XXXXXXXXXXXXXXXX

# ---------------------------------------------------------------------------
# Convex-only env vars (set via `just env-set KEY VALUE`, not bundled in the app).
# Documented here so a fresh checkout has a single place to find every secret.
# ---------------------------------------------------------------------------

# WorkOS server key — used by Convex actions for the management API
WORKOS_API_KEY=sk_live_01XXXXXXXXXXXXXXXXXX

# Cloudflare R2 — used by Convex actions to issue presigned upload URLs
R2_ACCOUNT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
R2_ACCESS_KEY_ID=XXXXXXXXXXXXXXXXXXXX
R2_SECRET_ACCESS_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
R2_BUCKET=your-bucket-name
R2_PUBLIC_BASE_URL=https://cdn.example.com
