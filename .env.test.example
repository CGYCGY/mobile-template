# Credentials and config for the Maestro E2E smoke test.
# Copy to .env.test and fill in. The values must correspond to a real user
# created in the WorkOS dashboard for the dev environment.
EXPO_PUBLIC_CONVEX_URL=https://your-test-deployment.convex.cloud
EXPO_PUBLIC_WORKOS_CLIENT_ID=client_01TESTXXXXXXXXXXXXX
EXPO_PUBLIC_WORKOS_REDIRECT_URI=mobiletemplate://auth/callback

E2E_USER_EMAIL=test@example.com
E2E_USER_PASSWORD=replace-me
